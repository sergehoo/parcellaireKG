# --- Secrets & environnement ---
.env
.env.*
# gabarit sans secret : DOIT être versionné
!.env.example

# --- Python / Django ---
__pycache__/
*.py[cod]
*$py.class
*.sqlite3
celerybeat-schedule.db
celerybeat-schedule

# --- Node / Tailwind ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE / OS ---
.idea/
.vscode/
.DS_Store

# --- Build / artefacts ---
staticfiles/
media/
*.log

# Override compose local (ports/URLs propres à chaque poste de dev)
docker-compose.override.yml

# Le CSS compilé doit être committé (sinon le serveur ne sert rien
# tant qu'on n'a pas lancé `npm run build:css` en prod).
!static/css/tailwind.css
