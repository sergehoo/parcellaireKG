# Réduit le contexte de build Docker (~25 Go → quelques Mo).
# Sans ce fichier, `COPY . /app/` embarque media/, .git/ et venv/ :
# chaque build transférait tout au daemon. Au runtime ces dossiers
# sont fournis par les bind-mounts du docker-compose, pas par l'image.
.git
.gitignore
.idea
.vscode
.DS_Store
.env
.env.*

# Python
venv/
__pycache__/
*.py[cod]
*.sqlite3
celerybeat-schedule.db

# Node — le stage frontend fait son propre npm install
node_modules/
frontend/node_modules/

# Données volumineuses (bind-mount ./media:/app/media au runtime)
media/
staticfiles/
*.log
