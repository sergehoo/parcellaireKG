# =============================================================================
#  KAYDAN Parcellaire — Gabarit d'environnement (.env.example)
# =============================================================================
#  Copiez ce fichier en `.env` puis renseignez les vraies valeurs :
#      cp .env.example .env
#
#  ⚠️  NE JAMAIS committer le `.env` réel (il est ignoré par git).
#  ⚠️  Toutes les valeurs ci-dessous sont des PLACEHOLDERS : à remplacer.
#
#  En production, docker-compose force DJANGO_ENV=prod et DEBUG=False
#  (bloc `environment:`), quel que soit le contenu de ce fichier.
# =============================================================================

# --- Environnement Django -----------------------------------------------------
# 'prod' => parcelaireKG/settings/prod.py ; 'dev' => dev.py.
# (En Docker, la valeur est déjà forcée à `prod` dans docker-compose.yml.)
DJANGO_ENV=prod
DEBUG=False

# --- Secret & hôtes -----------------------------------------------------------
# Générer une clé neuve (NE PAS réutiliser une clé ayant déjà servi) :
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=CHANGE_ME_generer_une_cle_secrete_unique

# Domaines autorisés (séparés par des virgules), sans schéma.
ALLOWED_HOSTS=parcelaire.mondomaine.com,localhost,127.0.0.1
# Origines de confiance pour le CSRF (AVEC le schéma https://).
CSRF_TRUSTED_ORIGINS=https://parcelaire.mondomaine.com
# Domaine racine (sert à composer l'hôte S3 externe par défaut).
DOMAIN=mondomaine.com

# --- Base de données PostGIS --------------------------------------------------
DB_NAME=parcelaire
DB_USER=parcelaire
DB_PASSWORD=CHANGE_ME_mot_de_passe_bdd_fort
# En Docker, DB_HOST est déjà forcé au nom du service (parcelairedb).
DB_HOST=parcelairedb
DB_PORT=5432

# --- HTTPS / sécurité (valeurs par défaut prod déjà sûres) --------------------
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
CSP_ENABLED=True

# --- E-mail (rapports exécutifs, notifications) -------------------------------
# Laisser EMAIL_HOST vide => aucun envoi tenté (backend « dummy »).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=CHANGE_ME_mot_de_passe_smtp
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=KAYDAN Parcellaire <no-reply@mondomaine.com>

# --- Redis / Celery -----------------------------------------------------------
# En Docker, CELERY_BROKER_URL/RESULT_BACKEND sont déjà pointés sur le
# service `redis` dans docker-compose.yml. À renseigner seulement hors Docker.
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Stockage objet MinIO / S3 (orthophotos TIFF source) ----------------------
MINIO_ROOT_USER=CHANGE_ME_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_mot_de_passe_fort
MINIO_BUCKET=parcelaire-orthophotos
# Hôte public HTTPS pour les URLs présignées (par défaut : s3-parcelaire.$DOMAIN).
MINIO_S3_HOST=s3-parcelaire.mondomaine.com

# --- Intégration CRM externe (lots) -------------------------------------------
EXTERNAL_LOTS_API_URL=https://crm.exemple.com/api
EXTERNAL_LOTS_API_KEY=CHANGE_ME
EXTERNAL_LOTS_API_USERNAME=CHANGE_ME
EXTERNAL_LOTS_API_PASSWORD=CHANGE_ME

# --- Interopérabilité SAP (facultatif) ----------------------------------------
SAP_BASE_URL=
SAP_TOKEN_URL=
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=CHANGE_ME
SAP_TIMEOUT=30
SAP_VERIFY_SSL=True

# --- Divers -------------------------------------------------------------------
SITE_ID=1
TIME_ZONE=Africa/Abidjan
